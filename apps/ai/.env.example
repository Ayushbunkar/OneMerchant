# ============================================================
# OneMerchant AI Service — Environment Variables
# ============================================================

# PostgreSQL connection (same DB as the Node.js backend)
DATABASE_URL=postgresql://postgres:password@localhost:5432/onemerchant

# Redis connection
REDIS_URL=redis://localhost:6379/1

# OpenAI API Key (optional — chat engine falls back to rule-based mode)
OPENAI_API_KEY=sk-your-openai-api-key-here

# AI Model to use (default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# Service configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
